dlist_g2 <- readRDS("dlist_g2_preIPW.rds")
dlist_g3 <- readRDS("dlist_g3_preIPW.rds")




###################################################################
# 2. CREATE STABILIZED IPW FOR COMPARISON GROUP: ART vs Infertility
###################################################################

make_ipw_g1 <- function(df, trunc = NULL) {
  g <- as.integer(as.character(df$Group_2)=="1")  # the ref is ART
  if (length(unique(g)) != 2) stop("Group_2 has only one level in this dataset")
  
  fit_den <- glm(g ~ Maternal_Country + Smoke + ns(BMI, df=3) + ns(AR, df=3) + ns(Entry_age, df=3) 
                 + SEI + Education + ASTMA + ULCOLIT + pooled_diseases,
                 family = binomial(link= "logit"), data = df)
  den_1 <- predict(fit_den, type = "response")
  
  eps <- 1e-6
  den_1 <- pmin(pmax(den_1, eps), 1 - eps)  # numerical guard
  
  n  <- mean(g == 1)
  sw <- ifelse(g == 1, n/den_1, (1 - n)/(1 - den_1))
  
  if (!is.null(trunc)) {                     
    q  <- quantile(sw, probs = trunc, na.rm = TRUE)
    sw <- pmin(pmax(sw, q[1]), q[2])
  }
  
  # Save the Propensity score to the dataframe
  df$ps <- den_1
  
  df$sw <- sw
  df
}
# Compute weights for each imputed dataset 
dlist_w1 <- lapply(dlist_g1, make_ipw_g1, trunc = NULL)
winsorized_w1 <- lapply(dlist_g1, make_ipw_g1, trunc = c(0.01, 0.99))




