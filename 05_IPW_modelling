################################################################
# 6. Function to censor follow-up at tau years for all outcomes
################################################################

# 6.1 Comparison groups ART vs Infertility and Infertility vs 
# no infertility will be all censored at 30 years while the one with ICSI
# vs Infertility is censored at 25 years

add_censor <- function(df, tau = 30) {
  # Define event/followup pairs
  outcomes <- c("Coronary", "Stroke", "Diabetes", "HF",
                "Hemorrhage", "Kidney", "Aortic")
  
  for (o in outcomes) {
    event_var    <- paste0(o, "_event")
    follow_var   <- paste0(o, "_followup")
    event_cens   <- paste0(o, "_event_cens")
    time_cens    <- paste0(o, "_time_cens")
    
    # Apply censoring
    df[[event_cens]] <- ifelse(df[[follow_var]] > tau, 0, df[[event_var]])
    df[[time_cens]]  <- pmin(df[[follow_var]], tau)
  }
  
  return(df)
}

# 6.2 Apply to all imputed datasets with weights

#ART vs Infertility
dlist_w1 <- lapply(dlist_w1, add_censor, tau = 30)
winsorized_w1 <- lapply(winsorized_w1, add_censor, tau = 30)

