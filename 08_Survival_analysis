stack_results <- function(pooled_list, 
                          label){
  do.call(rbind, lapply(names(pooled_list), function(name){
    dat_i <- pooled_list[[name]]
    dat_i$outcome <- name
    dat_i$group   <- label
    return(dat_i)
  }))
}

# 4.7 Create the final table
all_results <- rbind(
  stack_results(pooled_g1, "Group_1"),
  stack_results(pooled_winsorized1, "winsor_1"),
  stack_results(pooled_g2, "Group_2"),
  stack_results(pooled_winsorized2, "winsor_2"),
  stack_results(pooled_g3, "Group_3"),
  stack_results(pooled_winsorized3, "winsor_3"),
  stack_results(pooled_g4, "Group_4"),
  stack_results(pooled_winsorized4, "winsor_4")
)

# 4.8 Sort and clean up column order
all_results <- all_results %>%
  select(group, outcome, tau, everything()) %>%
  arrange(group, outcome, tau) %>%
  mutate(across(where(is.numeric) & !tau, ~ round(.x, 2)))
view(all_results)

