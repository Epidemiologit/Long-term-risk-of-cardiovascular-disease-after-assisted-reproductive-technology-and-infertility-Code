#####################################
# 2. DEFINE THE EFFECT ESTIMATES
#####################################
#' @description
#' The function get_risk_metrics_delta calculates R, RD, and RR
#' at a single specific time point using the delta method for 
#' confidence intervals.
#' 
#' @param fit A \code{survfit} object 
#' @param tau numeric, times points (for comparison 1,2,3 is 10,20,30; for the 4 is 10,20,25)
#' @param outcome_name character, names of the diseases
#' 
#' @return A data frame containing point estimates and 95% CIs for Risks, RD, and RR.
#' 
get_risk_metrics_delta <- function(fit, 
                                   tau, 
                                   outcome_name) {
  s <- summary(fit, times = tau, extend = TRUE)
  S0 <- s$surv[1]; S1 <- s$surv[2]
  seS0 <- s$std.err[1]; seS1 <- s$std.err[2]
  
  # Risks
  R0 <- 1 - S0
  R1 <- 1 - S1
  
  # Risk CIs (delta method, SE same as survival, clamp to [0,1])
  clamp01 <- function(x) pmax(0, pmin(1, x))
  ci_R0 <- clamp01(c(R0 - 1.96 * seS0, R0 + 1.96 * seS0))
  ci_R1 <- clamp01(c(R1 - 1.96 * seS1, R1 + 1.96 * seS1))
  
  # Risk difference + CI
  RD <- R1 - R0
  se_RD <- sqrt(seS0^2 + seS1^2)   
  ci_RD <- c(RD - 1.96 * se_RD, RD + 1.96 * se_RD)
  
  # Risk ratio + CI (delta method on log scale)
  eps <- 1e-12
  R0p <- pmax(R0, eps); R1p <- pmax(R1, eps)
  RR <- R1p / R0p
  se_logRR <- sqrt((seS1^2) / (R1p^2) + (seS0^2) / (R0p^2))
  ci_RR <- exp(log(RR) + c(-1, 1) * 1.96 * se_logRR)
  
  data.frame(
    outcome = outcome_name,
    tau = tau,
    Risk0 = R0, CI_R0_low = ci_R0[1], CI_R0_high = ci_R0[2],
    Risk1 = R1, CI_R1_low = ci_R1[1], CI_R1_high = ci_R1[2],
    RD = RD, CI_RD_low = ci_RD[1], CI_RD_high = ci_RD[2],
    RR = RR, CI_RR_low = ci_RR[1], CI_RR_high = ci_RR[2]
  )
}


