#' @description 
#' Combines estimates from multiple imputations to 
#' produce a single pooled estimate and variance that
#'  accounts for imputation uncertainty via Rubin's Rules.
#'
#' @param res_list_outcome A list of data frames from \code{analyze_delta} for one outcome.
#' @param scale_to_percentage if true, multiplies RD by 100.
#'
#' @return A data frame of pooled estimates with 95% confidence intervals

# 4.1 MI pooling 
.pool_scalar <- function(q, u){
  m <- length(q)
  qbar <- mean(q)
  ubar <- mean(u)
  b    <- if (m > 1) var(q) else 0
  tvar <- ubar + (1 + 1/m)*b
  list(qbar = qbar, se = sqrt(tvar))
}

# 4.2 Derive within-imputation from CIs 
.se_from_ci <- function(lo, hi) (hi - lo) / (2*1.96)

safe_log <- function(x) log(pmax(x, .Machine$double.eps))

# 4.3 Pool risks, RD, RR at each tau
pool_effects <- function(res_list_outcome, scale_to_percentage = TRUE){
  all <- do.call(rbind, lapply(seq_along(res_list_outcome), function(i){
    cbind(res_list_outcome[[i]], imp = i)
  }))
  
  # 4.4 Scaling: 100 for %, 1 for decimals    
  mult <- if(scale_to_percentage) 100 else 1
  
  # 4.5 Split by tau(10, 20, 25, or 30)    
  do.call(rbind, lapply(split(all, all$tau), function(dat_i){
    # Risk0
    se_r0 <- .se_from_ci(dat_i$CI_R0_low, dat_i$CI_R0_high)
    pr0   <- .pool_scalar(dat_i$Risk0, se_r0^2)
    
    # Risk1
    se_r1 <- .se_from_ci(dat_i$CI_R1_low, dat_i$CI_R1_high)
    pr1   <- .pool_scalar(dat_i$Risk1, se_r1^2)
    
    # RD
    se_rd <- .se_from_ci(dat_i$CI_RD_low, dat_i$CI_RD_high)
    prd   <- .pool_scalar(dat_i$RD, se_rd^2)
    
    # RR 
    se_lrr <- .se_from_ci(safe_log(dat_i$CI_RR_low), safe_log(dat_i$CI_RR_high))
    plrr   <- .pool_scalar(safe_log(dat_i$RR), se_lrr^2)
    
    
    data.frame(
      tau = dat_i$tau[1],
      Risk0 = pr0$qbar*mult,
      Risk0_lo = pmax(0, pr0$qbar - 1.96*pr0$se)*mult,
      Risk0_hi = pmin(1, pr0$qbar + 1.96*pr0$se)*mult,
      
      Risk1 = pr1$qbar*mult,
      Risk1_lo = pmax(0, pr1$qbar - 1.96*pr1$se)*mult,
      Risk1_hi = pmin(1, pr1$qbar + 1.96*pr1$se)*mult,
      
      RD = prd$qbar*mult,
      RD_lo = (prd$qbar - 1.96*prd$se)*mult,
      RD_hi = (prd$qbar + 1.96*prd$se)*mult,
      
      RR = exp(plrr$qbar),
      RR_lo = exp(plrr$qbar - 1.96 * plrr$se),
      RR_hi = exp(plrr$qbar + 1.96 * plrr$se)
    )
  }))
}

# 4.6 Apply to each outcome for each comparison
# ART vs Infertility
pooled_g1 <- lapply(res_all_w1, pool_effects)  
pooled_winsorized1 <- lapply(res_winsorized_1, pool_effects)  

