#' @description 
#' Runs across multiple outcomes and imputed datasets to 
#' compute weighted Kaplan-Meier models and extract effect estimates.
#' 
#' @param dlist list of imputed dataframes
#' @param group_var  variable defining the comparison group (eg: Group_1)
#' @param outcome name of the diseases studied
#' @param taus time points
#' 
#' @return A named list of lists containing survival estimates for each outcome.
#' 
analyze_delta <- function(dlist, group_var, 
                          outcomes = c("Coronary","Stroke","Diabetes","HF","Hemorrhage","Kidney","Aortic"),
                          taus = c(10,20,30)) {
  res <- list()
  
  for (o in outcomes) {
    message("Processing Outcome: ", o, " for ", group_var)
    
    tvar <- paste0(o, "_time_cens")
    evar <- paste0(o, "_event_cens")
    fml <- as.formula(paste0("Surv(", tvar, ",", evar, ") ~ ", group_var))
    
    res[[o]] <- lapply(seq_along(dlist), function(i) {
      dat_i <- dlist[[i]]
      
      # Check if the weights column actually exists in this specific imputation
      if (!"sw" %in% names(dat_i)) {
        warning(paste("Dataset index", i, "is missing the 'sw' column. Skipping."))
        return(NULL)
      }
      
      dat_i[[group_var]] <- factor(dat_i[[group_var]], levels = c("0","1"))
      
      if (length(na.omit(unique(dat_i[[group_var]]))) < 2) return(NULL)
      
      fit <- survival::survfit(fml, data = dat_i, weights = sw, conf.type = "plain")
      
      do.call(rbind, lapply(taus, function(tau) {
        get_risk_metrics_delta(fit, tau, o)
      }))
    })
  }
  return(res)
}

