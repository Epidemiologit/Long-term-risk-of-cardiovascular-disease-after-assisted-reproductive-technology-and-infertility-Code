# 7. Unweighted Analysis (Same variables but no weights)
# #######################################################

# Helper: standard SMD for continuous (Unweighted)
smd_cont_unw <- function(m1, m0, s1, s0) {
  den <- sqrt((s1^2 + s0^2) / 2)
  ifelse(is.finite(den) & den > 0, (m1 - m0) / den, NA_real_)
}

# Helper: standard SMD for proportions (Unweighted)
smd_prop_unw <- function(p1, p0) {
  den <- sqrt((p1*(1-p1) + p0*(1-p0))/2)
  ifelse(is.finite(den) & den > 0, (p1 - p0)/den, NA_real_)
}

one_imp_unw <- function(d){
  grp <- sort(unique(d$Group_2))
  nonart <- grp[1]; art <- grp[2]
  
  map_dfr(all_vars, function(v){
    
    # for continuous variables (Unweighted)
    if(v %in% cont_vars){
      
      d %>%
        filter(!is.na(.data[[v]]), !is.na(Group_2)) %>%
        group_by(Group_2) %>%
        summarise(
          # Standard mean and SD
          mean_val = mean(.data[[v]], na.rm = TRUE),
          sd_val   = sd(.data[[v]], na.rm = TRUE), 
          .groups = "drop"
        ) %>%
        pivot_wider(
          names_from = Group_2, 
          values_from = c(mean_val, sd_val),
          names_prefix = "g"
        ) %>%
        mutate(
          variable = v,
          level    = "Mean (SD)",
          type     = "cont",
          
          mean_nonart = .data[[paste0("mean_val_g", nonart)]],
          sd_nonart   = .data[[paste0("sd_val_g", nonart)]],
          mean_art    = .data[[paste0("mean_val_g", art)]],
          sd_art      = .data[[paste0("sd_val_g", art)]],
          
          SMD = smd_cont_unw(mean_art, mean_nonart, sd_art, sd_nonart)
        ) %>%
        select(variable, level, type, mean_nonart, sd_nonart, mean_art, sd_art, SMD)
      
      # Logic for categorical variables (Unweighted) 
    } else {
      
      d %>%
        filter(!is.na(.data[[v]]), !is.na(Group_2)) %>%
        # Standard count (NO wt argument)
        count(variable = v, level = .data[[v]], Group_2, name = "n") %>%
        group_by(variable, level) %>%
        complete(Group_2 = grp, fill = list(n = 0)) %>%
        ungroup() %>%
        group_by(variable, Group_2) %>%
        mutate(pct = n / sum(n)) %>%
        ungroup() %>%
        pivot_wider(
          names_from = Group_2, 
          values_from = c(n, pct),
          names_prefix = "g", 
          values_fill = list(n = 0, pct = 0)
        ) %>%
        mutate(
          type = "cat",
          p_nonart = .data[[paste0("pct_g", nonart)]],
          p_art    = .data[[paste0("pct_g", art)]],
          
          SMD_lvl  = smd_prop_unw(p_art, p_nonart),
          ref_lvl  = levels(d[[v]])[1],
          SMD      = if_else(as.character(level) == ref_lvl, NA_real_, SMD_lvl),
          
          # Mapping to generic columns
          mean_nonart = .data[[paste0("n_g", nonart)]],
          sd_nonart   = p_nonart, 
          mean_art    = .data[[paste0("n_g", art)]],
          sd_art      = p_art
        ) %>%
        select(variable, level, type, mean_nonart, sd_nonart, mean_art, sd_art, SMD)
    }
  })
}

# Run across imputations
imp_all_unw <- map(df, one_imp_unw) %>%
  bind_rows(.id = "imp") %>%
  mutate(imp = as.integer(imp))

# Pool results (Unweighted)
final_tbl_unweighted <- imp_all_unw %>%
  group_by(variable, level, type) %>%
  summarise(
    val_nonart_pooled = mean(mean_nonart, na.rm=TRUE), 
    val_nonart_sd_imp = sd(mean_nonart, na.rm=TRUE),   
    second_stat_nonart = mean(sd_nonart, na.rm=TRUE), 
    
    val_art_pooled    = mean(mean_art, na.rm=TRUE),
    val_art_sd_imp    = sd(mean_art, na.rm=TRUE),
    second_stat_art   = mean(sd_art, na.rm=TRUE),
    
    SMD = mean(SMD, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  mutate(
    `Non-ART` = case_when(
      type == "cat" ~ sprintf("%.0f ± %.0f (%.1f%%)", val_nonart_pooled, val_nonart_sd_imp, 100 * second_stat_nonart),
      type == "cont" ~ sprintf("%.2f (%.2f)", val_nonart_pooled, second_stat_nonart)
    ),
    `ART` = case_when(
      type == "cat" ~ sprintf("%.0f ± %.0f (%.1f%%)", val_art_pooled, val_art_sd_imp, 100 * second_stat_art),
      type == "cont" ~ sprintf("%.2f (%.2f)", val_art_pooled, second_stat_art)
    )
  ) %>%
  transmute(
    Variable = variable,
    Level    = as.character(level),
    `Non-ART`,
    `ART`,
    SMD
  ) %>%
  arrange(Variable, Level)

# View Unweighted Result
