    "Kidney" = "Chronic kidney disease",
    "Aortic" = "Aortic aneurysm or dissection"
  )
  
  # create the plots for the 2 supplemental outcomes
  plots_to_bundle <- lapply(seq_along(outcomes_sub), function(i){
    oc <- outcomes_sub[i]
    custom_title <- if(oc %in% names(outcome_titles)) outcome_titles[[oc]] else oc
    
    # Extract the RR text using the helper from Step 3
    eff_string <- make_eff_text(pooled_eff_list, oc, tau = 30, metric = "RR")
    
    plot_with_risktable(
      pooled_df     = curves_list[[oc]], 
      ylim          = ylims_list[[oc]], 
      group_levels  = group_levels,
      letter        = custom_title,         # Plain text title
      letter_y      = 0.85 * ylims_list[[oc]][2],
      eff_text      = eff_string,
      eff_y         = 0.85 * ylims_list[[oc]][2],
      analysis_type = NULL 
    )
  })
  
  # create the standalone legend 
  leg_data <- curves_list[[outcomes_sub[1]]]
  temp_p <- ggplot(leg_data, aes(x = time, y = (1 - surv_mean), color = group)) +
    geom_line(size = 1) +
    scale_color_manual(values = c("orange", "blue"), labels = group_levels, name = "Group") +
    theme_minimal(base_family = "Arial") +
    theme(legend.text = element_text(size = 9), 
          legend.title = element_text(size = 9, face = "bold"))
  
  shared_legend <- get_legend(temp_p)
  
  # add the legend as the 3rd item in the vertical stack
  plots_to_bundle[[3]] <- shared_legend
  
  # save in tiff
  file_path <- paste0(file_name, ".tif")
  tiff(filename = file_path, width = 5.0, height = 8.5, units = "in", 
       res = 300, compression = "lzw", type = "windows", family = "Arial")
  
  gridExtra::grid.arrange(
    grobs = plots_to_bundle, 
    ncol  = 1,
    heights = c(1, 1, 0.3) 
  )
  
  dev.off()
}

