save_group_bundle <- function(curves_list, 
                              ylims_list, 
                              pooled_eff_list, 
                              group_levels, 
                              file_name, 
                              analysis_type){
  
  # Map outcome internal names to the full ames for the manuscript
  outcome_titles <- c(
    "Coronary"   = "Acute myocardial infarction",
    "Diabetes"   = "Type 2 diabetes mellitus",
    "Stroke"     = "Cerebral ischemic conditions",
    "HF"         = "Heart failure",
    "Hemorrhage" = "Intracranial Hemorrhage",
    "Kidney"     = "Chronic kidney disease",
    "Aortic"     = "Aortic aneurysm or dissection"
  )
  
  active_outcomes <- names(curves_list)
  
  # create list of aligned grobs (plots)
  plots_to_bundle <- lapply(seq_along(active_outcomes), function(i){
    oc <- active_outcomes[i]
    
    # Lookup the long title
    custom_title <- if(oc %in% names(outcome_titles)) outcome_titles[[oc]] else oc
    
    plot_with_risktable(
      pooled_df     = curves_list[[oc]], 
      ylim          = ylims_list[[oc]], 
      group_levels  = group_levels,
      letter        = custom_title, 
      letter_y      = 0.92 * ylims_list[[oc]][2],
      eff_text      = make_eff_text(pooled_eff_list, oc, tau = 30, metric = "RR"),
      eff_y         = 0.85 * ylims_list[[oc]][2],
      analysis_type = NULL 
    )
  })
  
  # create the legend
  # Use the first outcome to generate a template for the legend
  leg_data <- curves_list[[1]]
  temp_p <- ggplot(leg_data, aes(x = time, y = (1 - surv_mean), color = group)) +
    geom_line(linewidth = 1) +
    scale_color_manual(values = c("orange", "blue"), labels = group_levels, name = "Group") +
    theme_minimal(base_family = "Arial") +
    theme(legend.text = element_text(size = 10), 
          legend.title = element_text(size = 10, face = "bold"))
  
  shared_legend <- get_legend(temp_p)
  
  plots_to_bundle[[length(active_outcomes) + 1]] <- shared_legend
  
  #  Save in tiff format
  file_path <- paste0(file_name, ".tif")
  
  # Adjust height: 
  # If outcomes > 5, I likely need more vertical space for 4 rows.
  final_height <- if(length(active_outcomes) > 5) 11.5 else 8.75
  
  tiff(filename = file_path, width = 7.5, height = final_height, units = "in", 
       res = 300, compression = "lzw", type = "windows", family = "Arial")
  
  gridExtra::grid.arrange(grobs = plots_to_bundle, ncol = 2)
  
  dev.off()
}



