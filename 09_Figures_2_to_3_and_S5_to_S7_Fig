#' @description
#' The function make_survlist takes the imputed data sets and computes the standardized
#' survival estimates
#' 
#' @param dlist a list of imputed data frames
#' @param group_var string. This indicates the comparison group
#' @param outcome string. The name of the disease
#' @param times numeric vector. It's the 0-30 year grid defined in section 3
#' 
#' @return A list of data frames containing survival and risk estimates. 

make_survlist <- function(dlist, 
                          group_var, 
                          outcome, 
                          times){
  
  # 1. Dynamically construct variable names from the outcome string
  tvar <- paste0(outcome, "_time_cens")
  evar <- paste0(outcome, "_event_cens")
  
  # 2. Creates the formula: Surv(time, event) ~ group
  fml  <- as.formula(paste0("Surv(", tvar, ",", evar, ") ~ ", group_var)) 
  
  lapply(dlist, function(df){
    # fit: Run the weighted KM model
    fit <- survfit(fml, 
                   data = df, 
                   weights = sw, 
                   conf.type = "plain")
    # s: Get summary at specific time points (grid)
    s   <- summary(fit, times = times, extend = TRUE)
    
    # Handle strata names (e.g., "Group_2=1")
    grp <- if (is.null(fit$strata)) rep("all", length(s$time)) else {
      rep(names(fit$strata), each = length(s$time)/length(fit$strata))
    }
    data.frame(
      time = s$time, group = grp, surv = s$surv, se = s$std.err, n_risk = s$n.risk,
      check.names = FALSE
    )
  })
}


#########################################
# 5. Defining Rubin's rule pooling logic 
#########################################
#' @description
#' takes a list of survival estimates from imputed data and returns pooled results
#' 
#' @param surv_list A list of data frames from \code{make_survlist}
#' 
#' @return a single data frame with pooled survival, variance and confidence intervals.
#' 
pool_survlist <- function(surv_list){
  # combine all the imputations into a single data set
  all <- do.call(rbind, lapply(seq_along(surv_list), function(i){
    x <- surv_list[[i]]; x$group <- as.character(x$group); cbind(x, imp = i)
  }))
  
  # Combine by time and group
  split_list <- split(all, list(all$time, all$group), drop = TRUE)
  
  pooled <- do.call(rbind, lapply(split_list, function(df){
    df <- df[complete.cases(df$surv, df$se, df$n_risk), ]
    if (!nrow(df)) return(NULL)
    
    m     <- length(unique(df$imp)) # number of imputations
    q_bar <- mean(df$surv) # pooled estimate (mean of means)
    u_bar <- mean(df$se^2) # within variance 
    b     <- if (m > 1) var(df$surv) else 0 # between variance
    
    #Rubin's rule: total variance= within_variance( u_bar) + (1+1/number of imputations(m=20) ) * between_variance(b)   
    t_var <- u_bar + (1 + 1/m)*b
    data.frame(
      time = df$time[1],
      group = df$group[1],
      surv_mean = q_bar,
      surv_total_var = t_var,
      lower = pmax(0, q_bar - 1.96*sqrt(t_var)),
      upper = pmin(1, q_bar + 1.96*sqrt(t_var)),
      n_risk = as.numeric(mean(df$n_risk, na.rm = TRUE)),
      check.names = FALSE
    )
  }))
  rownames(pooled) <- NULL
  pooled[order(pooled$group, pooled$time), ]
}


