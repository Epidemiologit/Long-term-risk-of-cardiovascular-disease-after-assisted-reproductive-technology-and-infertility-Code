#' @description
#' This code creates the formatted effect estimate for the plot
#' Extracts RR from a result list and format them into a string with confidence intervals
#' 
#' @param pooled_eff_list a named list of data frames containing outcome estimates
#' @param outcome character string. The names of the specific outcome (eg: acute myocardial infarction)
#' @param tau numeric. The time point at which to extract the estimate (at 30 years)
#' @param metric the effect estimate 
#' @param digits integer. Number of decimals requested for the effect estimate
#' @param prefix turned off
#' 
#' @return a character string eg: RR 1.30 (1.10,1.40)
#' 
make_eff_text <- function(pooled_eff_list, 
                          outcome, 
                          tau = 30,
                          metric = c("RR","RD"), 
                          digits = 2, 
                          prefix = NULL){
  
  metric <- match.arg(metric)
  df <- pooled_eff_list[[outcome]]
  
  # filter for the specific time point
  row <- df[df$tau == tau, ]
  if (nrow(row) != 1) return(NULL)
  
  # formatting with sprintf 
  if (metric == "RR") {
    core <- paste0("RR ", sprintf(paste0("%.",digits,"f"), row$RR),
                   " (", sprintf(paste0("%.",digits,"f"), row$RR_lo),
                   ",",  sprintf(paste0("%.",digits,"f"), row$RR_hi), ")")
  } 
  if (!is.null(prefix)) paste(prefix, core) else core
}

