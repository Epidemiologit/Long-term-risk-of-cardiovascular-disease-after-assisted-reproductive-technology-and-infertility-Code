#' @description
#' The function build_pooled_curve is a wrapper that takes the 2 previous functions 
#' make_survlist and pool_survlist, extracts the survival data from imputed data sets, applies 
#' Rubin's Rules for pooling, and applies clean factor labels for plotting.
#' 
#' @param dlist a list of data frames (the imputed data sets)
#' @param group_var character, the name of the comparison group (eg: Group_1, Group_2)
#' @param outcomes character vector, the name of the diseases
#' @param grid numeric vector, the time grid of evaluation (from 0 to 30, by 0.5) defined in  step 3
#' @param labels Character vector, clean labels for the group levels (e.g: c("ART", "no ART"))
#' 
#' @return A named list of data frames, where each element corresponds to an 
#'         outcome and contains the pooled survival estimates and confidence intervals.
#' 
build_pooled_curves <- function(dlist,
                                group_var, 
                                outcomes, 
                                grid, 
                                labels){
  out <- lapply(outcomes, function(o){
    # 1. Extraction: call the 'make_survlist' helper from step 4
    lst    <- make_survlist(dlist, group_var, o, grid)
    # 2. Pooling: Call pool_survlist helper from step 5 to apply Rubin's rule
    #    to lst produced in the previous line
    pooled <- pool_survlist(lst)
    # 3. Formatting: Convert group to a factor
    pooled$group   <- factor(pooled$group,
                             levels = paste0(group_var, "=", c("1","0")),
                             labels = labels)
    
    # 4. Identification: Tag the data frame with the outcome name
    pooled$outcome <- o
    pooled
  })
  
  # 5. Organization: Name the list elements for easy access (e.g., out$Stroke)
  names(out) <- outcomes
  out
}


#########################################################
# 7. Plotting helpers 
#########################################################
#' @description
#' The function plot_pooled_curve defines the characteristics 
#' to plot each survival curve
#' 
#' @param pooled_df a data frame containing pooled survival estimates from \code{pool_survlist}
#' @param ylim numeric vector defining the y-axis limits
#' @param letter character labeling each panel (eg: "A", "B" etc..)
#' @param letter_y numeric, vertical position of the panel letter
#' @param eff_text character string containing the effect estimate (RR)
#' @param eff_y numeric, vertical position of the effect estimate
#' @param analysis_type character vector for the type of analysis
#' 
#' @return a ggplot object
#' 

plot_pooled_curve <- function(pooled_df, 
                              ylim,
                              letter = NULL, 
                              letter_y = NULL,
                              eff_text = NULL, 
                              eff_y = NULL,
                              analysis_type=NULL) {
  # 1. internal helper: vertical positioning
  #put the effect estimate at 85% of the height of the y axis
  y_annot <- function(y) if (is.null(y)) 0.85*ylim[2] else y
  
  # 2. base plotting layer
  # surv_mean is plotted to convert survival into cumulative incidence
  p <- ggplot(pooled_df, aes(time, 1 - surv_mean, color = group, fill = group)) +
    geom_line(size = 1) +
    # Shaded confidence intervals 
    geom_ribbon(aes(ymin = 1 - upper, ymax = 1 - lower), alpha = 0.2, color = NA) +
    
    scale_x_continuous(limits = c(0, 30), breaks = seq(0, 30, 5), expand = c(0, 0)) +
    scale_y_continuous(limits = ylim, expand = c(0, 0)) +
    scale_color_manual(values = c("orange","blue"), breaks = levels(pooled_df$group)) +
    scale_fill_manual(values  = c("orange","blue"),  breaks = levels(pooled_df$group)) +
    labs(x = "Years", y = "Cumulative incidence") +
    theme_minimal(base_family = "Arial") +
    theme(
      panel.grid = element_blank(),
      axis.line = element_line(),
      axis.ticks = element_line(),
      axis.title = element_text(size = 9),    
      axis.text = element_text(size = 8),
      legend.position = "none",
      text = element_text(family = "Arial")
    )
  # 3. conditional annotations:
  if (!is.null(letter))
    p <- p + annotate("text", x = 0.5,  y = y_annot(eff_y),
                      label = letter, 
                      fontface = "plain", 
                      size = 2.8,        
                      hjust = 0)
  #adds effect estimates
  if (!is.null(eff_text))
    p <- p + annotate("text", x = 29.5, y = y_annot(eff_y),
                      label = eff_text, hjust = 1,
                      size = 2.8)
  
  
  if (!is.null(analysis_type))
    p <- p + annotate("text", x = 15, y = ylim[2], 
                      label = analysis_type, vjust = 1.5, fontface = "italic")
  
  p
}


# 4. Helper to extract the legend from a ggplot object
get_legend <- function(my_plot) {
  tmp <- ggplotGrob(my_plot)
  leg <- which(sapply(tmp$grobs, function(x) x$name) == "guide-box")
  legend <- tmp$grobs[[leg]]
  return(legend)
}

#########################################################
# 8. Risk table
#########################################################
#' @description
#' the function make_risk_table extracts numbers at risk at specific time 
#' intervals and formats them into a Grob
#' 
#' @param pooled_df a data frame with pooled estimates
#' @param group_level character vector (eg: c("ART", "no ART"))
#' 
#' @return a grob object representing the risk table



make_risk_table <- function(pooled_df, 
                            group_levels = NULL,
                            ticks = c(0, 5, 10, 15, 20, 25, 30)){
  
  actual_groups <- unique(as.character(pooled_df$group))
  
  out <- do.call(rbind, lapply(actual_groups, function(g){
    df_g <- pooled_df[pooled_df$group == g, ]
    rows <- if (nrow(df_g) == 0) {
      rep(NA_real_, length(ticks)) 
    } else {
      vapply(ticks, function(tk){
        idx <- which.min(abs(df_g$time - tk))
        as.numeric(df_g$n_risk[idx])
      }, numeric(1))
    }
    df_row <- data.frame(Group = g, t(round(rows)), check.names = FALSE)
    names(df_row) <- c("Group", as.character(ticks))
    df_row
  }))
  
  #  Defining the theme
  tt <- gridExtra::ttheme_minimal(
    base_family = "Arial",
    core = list(
      fg_params = list(fontfamily="Arial", fontsize = 6, hjust = 0, x = 0.1),
      bg_params = list(fill = NA, col = "grey80", lwd = 0.5) # lwd adds line thickness
    ),
    colhead = list(
      fg_params = list(fontfamily="Arial", fontsize = 6, hjust = 0, x = 0.1),
      bg_params = list(fill = "grey95", col = "grey80", lwd = 0.5)
    ),
    rowhead = list(
      fg_params = list(fontfamily="Arial", fontsize = 6, hjust = 0, x = 0.1),
      bg_params = list(fill = NA, col = "grey80", lwd = 0.5)
    )
  )
  
  tbl <- gridExtra::tableGrob(out, rows = NULL, theme = tt)
  
  # Adjust padding inside cells
  tbl$padding <- grid::unit(c(0.1, 1.5, 0.1, 1.5), "mm")
  tbl
}

#########################################################
# 9. Align Survival Plot and Risk Table 
#########################################################
#' @description
#' A layout manager that extracts internal plot dimensions to 
#' align the risk table's columns with the ggplot's X-axis.
#' 
#' @param pooled_df data frame of pooled survival estimates
#' @param ylim numeric vector for y-axis limits
#' @param group_levels character vector defining the comparison groups
#' @param letter letter for the panels
#' @param letter_y y-coordinate for the panel label
#' @param eff_text effect estimate string 
#' @param eff_y y-coordinate for the effect text.
#' @param analysys_type description of the analysis 
#' 
#' @return a gtable object containing the aligned plot and table
#' 
# general function that accepts every parameter for the plot and the table
plot_with_risktable <- function(pooled_df, 
                                ylim, 
                                group_levels, 
                                letter = NULL, 
                                letter_y = NULL, 
                                eff_text = NULL, 
                                eff_y = NULL, 
                                analysis_type = NULL){
  
  # create the survival plot 
  p <- plot_pooled_curve(pooled_df, ylim, 
                         letter = letter, 
                         letter_y = letter_y,
                         eff_text = eff_text, 
                         eff_y = eff_y,
                         analysis_type = analysis_type) +
    theme(
      # Adds room on the right so the table doesn't touch the next panel
      plot.margin = margin(0,0,0,0),
      # Draws a border to separate panels
      panel.border = element_rect(colour = "grey70", fill = NA, size = 0.5),
      axis.title.y = element_text(margin = margin(r = 8)),
      axis.title.x = element_text(margin = margin(t = 5, b = 2)), 
      legend.text  = element_text(size = 6),
      legend.title = element_text(size = 6)
    )
  
  # generate the risk table grob
  tbl <- make_risk_table(pooled_df, group_levels, ticks = risk_ticks)
  
  # align table widths to the plot panel
  gp <- ggplotGrob(p)
  pnl_col <- gp$layout[gp$layout$name == "panel", "l"][1]
  left_w  <- sum(gp$widths[1:(pnl_col - 1)]) 
  panel_w <- gp$widths[pnl_col]
  
  n_cols <- length(tbl$widths)
  if (n_cols >= 2) {
    tbl$widths[1] <- left_w
    tbl$widths[2:n_cols] <- rep(panel_w / (n_cols - 1), n_cols - 1)
  }
  
  combined_grob <- gridExtra::arrangeGrob(
    grid::nullGrob(),                                     # Spacer Top
    gp,                                                   # Plot
    grid::nullGrob(),                                     # Spacer Middle
    tbl,                                                  # The risk table
    ncol = 1, 
    heights = grid::unit.c(
      grid::unit(3, "mm"), 
      grid::unit(1, "null"), 
      grid::unit(3, "mm"), 
      grid::unit(1.2, "cm") 
    )
  )
  
  # Wrap in a viewport
  grid::grobTree(combined_grob, vp = grid::viewport(width = 0.92, height = 0.95))
}




