#' @description
#' The function build_pooled_curve is a wrapper that takes the 2 previous functions 
#' make_survlist and pool_survlist, extracts the survival data from imputed data sets, applies 
#' Rubin's Rules for pooling, and applies clean factor labels for plotting.
#' 
#' @param dlist a list of data frames (the imputed data sets)
#' @param group_var character, the name of the comparison group
#' @param outcomes character vector, the name of the diseases
#' @param grid numeric vector, the time grid of evaluation (from 0 to 25, by 0.5) defined in  step 3
#' @param labels Character vector, clean labels for the group levels (ICSI, Infertility))
#' 
#' @return A named list of data frames, where each element corresponds to an 
#'         outcome and contains the pooled survival estimates and confidence intervals.
#' 
build_pooled_curves_g4 <- function(dlist,
                                   group_var, 
                                   outcomes, 
                                   grid, 
                                   labels){
  out <- lapply(outcomes, function(o){
    # 1. Extraction: call the 'make_survlist' helper from step 4
    lst    <- make_survlist(dlist, group_var, o, grid)
    # 2. Pooling: call pool_survlist helper from step 5 to apply Rubin's rule
    #    to lst produced in the previous line
    pooled <- pool_survlist(lst)
    # 3. Formatting: convert group to a factor
    pooled$group   <- factor(pooled$group,
                             levels = paste0(group_var, "=", c("1","0")),
                             labels = labels)
    
    # 4. Identification: tag the data frame with the outcome name
    pooled$outcome <- o
    pooled
  })
  
  
  names(out) <- outcomes
  out
}


