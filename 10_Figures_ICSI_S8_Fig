#' @description
#' This code created the formatted effect estimate for the plot
#' Extracts RR from a result list and format them into a string with confidence intervals
#' 
#' @param pooled_eff a named list of data frames containing outcome estimates
#' @param outcome character string. The names of the specific outcome (eg: acute myocardial infarction)
#' @param tau numeric. The time point at which to extract the estimate ( 25 years)
#' @param metric effect estimate 
#' @param digits integer. Number of decimals requested for the effect estimate
#' @param prefix turned off
#' 
#' @return a character string eg: RR 1.30 (1.10,1.40)
#' 
make_eff_text <- function(pooled_eff, outcome, tau = 25, metric = "RR", digits = 2){
  # Safety: return empty string instead of NULL if data is missing
  if (!outcome %in% names(pooled_eff)) return("") 
  
  df <- pooled_eff[[outcome]]
  row <- df[df$tau == tau, ]
  
  if (nrow(row) != 1) return("") # Safety for missing time points
  
  paste0("RR ", sprintf("%.2f", row$RR), " (", 
         sprintf("%.2f", row$RR_lo), ",", sprintf("%.2f", row$RR_hi), ")")
}

