#' @description
#' The function plot_pooled_curve_g4 defines the characteristics 
#' to plot each survival curve
#' 
#' @param pooled_df a data frame containing pooled survival estimates from \code{pool_survlist}
#' @param ylim numeric vector defining the y-axis limits
#' @param letter optional character for panel labeling (eg: "A", "B" etc..)
#' @param letter_y numeric, vertical position of the panel letter
#' @param eff_text character string containing the effect estimate (RR)
#' @param eff_y numeric, vertical position of the effect estimate
#' 
#' @return a ggplot object
#' 


get_legend <- function(myggplot){
  tmp <- ggplotGrob(myggplot)
  leg <- which(sapply(tmp$grobs, function(x) x$name) == "guide-box")
  legend <- tmp$grobs[[leg]]
  return(legend)
}

plot_pooled_curve_g4 <- function(pooled_df, 
                                 ylim,
                                 letter = NULL, 
                                 letter_y = NULL,
                                 eff_text = NULL, 
                                 eff_y = NULL) {
  # internal helper: vertical positioning
  #put the effect estimate at 85% of the height of the y axis
  y_annot <- function(y) if (is.null(y)) 0.85*ylim[2] else y
  
  # base plotting layer
  # 1- surv_mean is plotted to convert survival into cumulative incidence
  p <- ggplot(pooled_df, aes(time, 1 - surv_mean, color = group, fill = group)) +
    geom_line(size = 1) +
    # Shaded confidence intervals 
    geom_ribbon(aes(ymin = 1 - upper, ymax = 1 - lower), alpha = 0.2, color = NA) +
    
    scale_x_continuous(limits = c(0, 25), breaks = seq(0, 25, 5), expand = c(0, 0)) +
    scale_y_continuous(limits = ylim, expand = c(0, 0)) +
    scale_color_manual(values = c("orange","blue"), breaks = levels(pooled_df$group)) +
    scale_fill_manual(values  = c("orange","blue"),  breaks = levels(pooled_df$group)) +
    labs(x = "Years", y = "Cumulative incidence") +
    theme_minimal(base_family = "Arial") +
    theme(
      panel.grid = element_blank(),
      axis.line = element_line(),
      axis.ticks = element_line(),
      legend.position = "none",
      text = element_text(family = "Arial")
    )
  # conditional annotations:
  # Adds outcome titles (Plain text, size 2.8, aligned with eff_y)
  if (!is.null(letter))
    p <- p + annotate("text", x = 0.5,  y = y_annot(eff_y),
                      label = letter, fontface = "plain", size = 2.8, hjust = 0)
  
  # Adds effect estimates (RR)
  if (!is.null(eff_text))
    p <- p + annotate("text", x = 24.5, y = y_annot(eff_y),
                      label = eff_text, hjust = 1, size = 2.8)
  
  p
}


