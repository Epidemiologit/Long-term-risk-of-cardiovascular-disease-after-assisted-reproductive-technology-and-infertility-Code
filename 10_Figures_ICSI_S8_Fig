###########################################
#11. Save
############################################
save_group_bundle_g4 <- function(curves_list, ylims_list, pooled_eff_list, group_levels, file_name, analysis_type) {
  
  target_outcomes <- c("Coronary", "Diabetes","Stroke", "HF", "Hemorrhage", "Kidney", "Aortic")
  
  outcome_titles <- c(
    "Coronary"   = "Acute myocardial infarction",
    "Diabetes"   = "Type 2 diabetes mellitus",
    "Stroke"     = "Cerebral ischemic conditions",
    "HF"         = "Heart failure",
    "Hemorrhage" = "Intracranial Hemorrhage",
    "Kidney"     = "Chronic kidney disease",
    "Aortic"     = "Aortic aneurysm or dissection"
  )
  
  #  Build the 7 plot grobs
  plots_to_bundle <- lapply(seq_along(target_outcomes), function(i) {
    oc <- target_outcomes[i]
    plot_with_risktable_g4(
      pooled_df    = curves_list[[oc]],
      ylim         = ylims_list[[oc]],
      group_levels = group_levels,
      letter       = outcome_titles[[oc]],
      eff_text     = make_eff_text(pooled_eff_list, oc, tau = 25),
      eff_y        = 0.85 * ylims_list[[oc]][2]
    )
  })
  
  # Extract Shared Legend
  leg_data <- curves_list[[1]]
  temp_p <- ggplot(leg_data, aes(x = time, y = (1 - surv_mean), color = group)) +
    geom_line(size = 1) +
    scale_color_manual(values = c("orange", "blue"), labels = group_levels, name = "Group") +
    theme_minimal(base_family = "Arial") +
    theme(legend.text = element_text(size = 9), legend.title = element_text(size = 9, face = "bold"))
  
  shared_legend <- get_legend(temp_p)
  
  
  plots_to_bundle[[8]] <- shared_legend 
  
  # Save to tiff
  file_path <- paste0(file_name, ".tif")
  tiff(filename = file_path, width = 8.5, height = 14, units = "in", 
       res = 300, compression = "lzw", type = "windows", family = "Arial")
  
  gridExtra::grid.arrange(
    grobs = plots_to_bundle, 
    ncol  = 2, 
    nrow  = 4
  )
  
  dev.off()
}
