# 8. Risk table
#########################################################
#' @description
#' the function make_risk_table extracts numbers at risk at specific time 
#' intervals and formats them into a Grob.
#' 
#' @param pooled_df a data frame with pooled estimates
#' @param group_level character vector (ICSI, Infertility)
#' @param risk_ticks time frame (from 0 to 25 years by 0.5)
#' 
#' @return a grob object representing the risk table

make_risk_table <- function(pooled_df, 
                            group_levels = NULL,
                            risk_ticks = seq(0, 25, 5)){

  if (!is.null(group_levels)) {
    pooled_df$group <- factor(as.character(pooled_df$group), levels = group_levels)
  } else {
    pooled_df$group <- factor(as.character(pooled_df$group))
  }
  
  
  pooled_df$n_risk <- suppressWarnings(as.numeric(pooled_df$n_risk))
  
  # build the table rows 
  out <- do.call(rbind, lapply(levels(pooled_df$group), function(g){
    

    df_g <- subset(pooled_df, group == g)
    rows <- if (!nrow(df_g)) rep(NA_real_, length(risk_ticks)) else vapply(
      risk_ticks, function(tk){
        idx <- which.min(abs(df_g$time - tk))
        if (length(idx) == 0L) NA_real_ else as.numeric(df_g$n_risk[idx])
      }, numeric(1)
    )
    
    nm <- c("Group", as.character(risk_ticks))
    df_row <- data.frame(Group = g, t(round(rows)), check.names = FALSE)
    names(df_row) <- nm
    df_row
  }))
  
  # define the visual theme 
  tt <- gridExtra::ttheme_minimal(
    base_family = "Arial",
    core    = list(fg_params = list(fontfamily="Arial", fontsize = 8, hjust = 0, x = 0),
                   bg_params = list(fill = NA, col = "grey80")),
    colhead = list(fg_params = list(fontfamily="Arial", fontsize = 8, hjust = 0, x = 0),
                   bg_params = list(fill = "grey95", col = "grey80")),
    rowhead = list(fg_params = list(fontfamily="Arial", fontsize = 8, hjust = 0, x = 0),
                   bg_params = list(fill = NA, col = "grey80"))
  )
  
  # convert the processed data frame into a Grob
  tbl <- gridExtra::tableGrob(out, rows = NULL, theme = tt)
  
  # Adjust padding
  tbl$padding <- grid::unit(c(0.5, 1.5, 0.5, 1.5), "mm")
  tbl
}


#########################################################
# 9. Align Survival Plot and Risk Table 
#########################################################
#' @description
#' A layout manager that extracts internal plot dimensions to 
#' physically align a risk table's columns with a ggplot's X-axis.
#' 
#' @param pooled_df data frame of pooled survival estimates
#' @param ylim numeric vector for Y-axis limits
#' @param group_levels character vector defining the comparison groups
#' @param letter letter for the panels
#' @param letter_y y-coordinate for the panel label
#' @param eff_text effect estimate string 
#' @param eff_y y-coordinate for the effect text.
#' 
#' @return a gtable object containing the aligned plot and table
#' 
plot_with_risktable_g4 <- function(pooled_df, ylim, group_levels, letter = NULL, eff_text = NULL, eff_y = NULL){
  
  # Create the plot 
  p <- plot_pooled_curve_g4(pooled_df, ylim, letter = letter, eff_text = eff_text, eff_y = eff_y) +
    theme(
      plot.margin = margin(0, 0, 0, 0),
      panel.border = element_rect(colour = "grey70", fill = NA, size = 0.5),
      axis.title.x = element_text(margin = margin(t = 5, b = 2))
    )
  
  # Generate the risk table 
  tbl <- make_risk_table(pooled_df, group_levels, risk_ticks = seq(0, 25, 5))
  
  gp <- ggplotGrob(p)
  pnl_col <- gp$layout[gp$layout$name == "panel", "l"][1]
  left_w  <- sum(gp$widths[1:(pnl_col - 1)]) 
  panel_w <- gp$widths[pnl_col]
  
  n_cols <- length(tbl$widths)
  if (n_cols >= 2) {
    tbl$widths[1] <- left_w
    tbl$widths[2:n_cols] <- rep(panel_w / (n_cols - 1), n_cols - 1)
  }
  
  combined_grob <- gridExtra::arrangeGrob(
    grid::nullGrob(),      # Spacer Top 
    gp,                    # The Survival Plot
    grid::nullGrob(),      # Spacer Middle 
    tbl,                   # The Risk Table
    ncol = 1, 
    heights = grid::unit.c(
      grid::unit(3, "mm"), 
      grid::unit(1, "null"), 
      grid::unit(4, "mm"), # Increased middle spacer
      grid::unit(1.2, "cm") 
    )
  )
  
  
  grid::grobTree(combined_grob, vp = grid::viewport(width = 0.92, height = 0.96))
}

