		  input(substr(B_date,1,4),4.) as year,
          input(substr(B_date,6,2),2.) as month,
          input(substr(B_date,9,2),2.) as day,
		  mdy( calculated month, calculated day, calculated year) as Birth_date format ddmmyy10.,
		  case when grdbs NE . then calculated Birth_date - grdbs
		       else calculated Birth_date - 280
