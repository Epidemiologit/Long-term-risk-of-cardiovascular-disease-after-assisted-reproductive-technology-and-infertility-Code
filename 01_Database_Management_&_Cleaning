   else sle="0";
   if NJURSJUK in ("1", "2") then njursjuk="1";
   else njursjuk="0";
   if EPILEPSI in ("1", "2") then epilepsi="1";
   else epilepsi="0";

   if Fertility_status ne " " and Maternal_Country ne " " and Smoke ne " " and bmi_c ne " " and age_c ne " " and AR ne .  then CCA="1";
   
   /*Variables for the 4 comparison groups*/
   if Fertility_status=2 then Group_1="1"; /*ART vs no ART*/
   else Group_1="0";

   if Fertility_status=1 then Group_2="0"; /*ART vs Infertility*/
   else if Fertility_status=2 then Group_2="1";
   else Group_2=" ";

   if Fertility_status=1 then Group_3="0"; /*ICSI vs Infertility*/
   if ICSI=1 then Group_3="1";

   if Fertility_status=0 then Group_4="0"; /*Infertility vs no Infertility*/
   else  Group_4="1";
    
   /* categorical calendar year*/
   if AR ge 1992 and AR le 1995 then AR_c="1";
   else if AR ge 1996 and AR le 1998 then AR_c="2";
   else if AR gt 1998 then AR_c="3";

   /*Remove superfluous variables*/
   drop mfoddatn PARITET_F B_date year infertility_dia count_infertility migr_date 
        emigration immigration_date exclusion_for_immigration month Maternal_Birthdate id_reused ID_mat
		ID_pat g0 prior_art n_art n_births excl Myear Mmonth Mother_birth rok1 infertility_date occupation
        ICSI Exclusion_previous_disease;
run;
