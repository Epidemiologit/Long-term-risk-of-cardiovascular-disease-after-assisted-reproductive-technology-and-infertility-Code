/* H : Emigration*/
proc sql;
   create table Emigration as
        select a.id_mat, 
			   a.b_date,
			   b.m_type,
			   input(substr(b.m_date,1,4),4.) as m_year,
               input(substr(b.m_date,6,2),2.) as m_month,
               input(substr(b.m_date,9,2),2.) as m_day,
			   mdy( calculated m_month, calculated m_day, calculated m_year) as Migr_date format ddmmyy10.,
               
			   input(substr(a.b_date,1,4),4.) as Year,
			   input(substr(a.b_date,6,2),2.) as Month,
               input(substr(a.b_date,9,2),2.) as day,
			   mdy( calculated month, calculated day, calculated year) as Birth_date format ddmmyy10.,
			   1 as Emigration
		from study_base as a
	    inner join Repro2.repro_migration as b
		on	a.ID_mat = b.ID
        where b.m_type="Utv" and calculated Migr_date ne . and calculated Migr_date ge calculated Birth_date
		      and calculated year le 2002 and calculated year ge 1992
        order by id_mat, b_date, Migr_date;
quit;

data Emigration;
   set Emigration;
   drop day month year m_day m_month m_year m_type;
run;
/*Dataset ready for the merge*/
proc sort data=Emigration nodupkey dupout=duplicates; by id_mat; run;




/* I: Immigration*/
/*With this dataset we exclude 10,725 women that arrived in Sweden from 9 to 0 months before their delivery 
  because we don't know if they had fertility treatments or if they had cardiovascular complications
  during pregnancy while non in Sweden. Dataset ready for the merge*/

proc sql;
   create table Immigration as
        select a.id_mat, 
			   a.b_date,
			   b.m_type,
			   input(substr(b.m_date,1,4),4.) as m_year,
               input(substr(b.m_date,6,2),2.) as m_month,
               input(substr(b.m_date,9,2),2.) as m_day,
			   mdy( calculated m_month, calculated m_day, calculated m_year) as Immigration_date format ddmmyy10.,
               
			   input(substr(a.b_date,1,4),4.) as Year,
			   input(substr(a.b_date,6,2),2.) as Month,
               input(substr(a.b_date,9,2),2.) as day,
			   mdy( calculated month, calculated day, calculated year) as Birth_date format ddmmyy10.,
			   calculated Birth_date-calculated Immigration_date as diff,
			   1 as Exclusion_for_immigration
		from study_base as a
	    inner join Repro.repro_migration as b
		on	a.ID_mat = b.ID
        where b.m_type="Inv" and calculated diff ge 0 and calculated diff le 280 and calculated year le 2002
              and calculated year ge 1992;
quit;

data Immigration;
   set Immigration;
   drop diff day month year m_day m_month m_year m_type Birth_date;
run;
proc sort data=Immigration nodupkey; by ID_mat b_date; run;




/* L: Death*/
/* Here there's a selection of women that died among the study participants 
   (women that delivered their first child between 1992 and 2002)*/

proc sql;
   create table death as
        select a.id_mat,
               input(substr(a.b_date,1,4),4.) as Year, 
		       a.b_date,
			   b.ddx label="Cause of death",
			   1 as Death,
               . as D_diagnosis length=3,
			   b.D_date
		from study_base as a
	    inner join Repro2.Repro_death_dia as b
		on	a.ID_mat = b.ID 
		where D_date ne " " and calculated year ge 1992 and calculated year le 2002
        order by ID_mat, b_date ;
quit;

/*Here I group the diagnostic codes for the diseases of interest.
  1) acute myocardial infarction
  2) intracranial hemorrhage
  3) cerebrovascular ischemic conditions
  4) diabetes
  5) kidney failure
  6) aortic aneurysm and dissection
  7) heart failure

  8 and 9 are the two exclusions flag variables
*/


proc sql;
   update death
       set D_diagnosis=
		case when  ddx like "I21%" or ddx like "410%" then 1 /* myocardial infarction */
			 when ddx like "I60%" or ddx like "I61%" or ddx like "I62%" or ddx like "430%" or ddx like "431%" or ddx like "432%" then 2 /* Intracranial emorrhage*/
             when ddx like "I63%" or ddx like "I65%" or ddx like "I66%" or ddx like "433%" or ddx like "434%" or ddx like "435%" then 3 /* Cerebrovascular ischemic conditions (Ischemic Stroke, TIA, and Large Artery Atherosclerosis)*/
			 when ddx like "E11%" or ddx like "250%" then 4 /* diabetes */
			 when ddx like "N18%" or ddx like "N19%" or ddx like "I12%" or ddx like "585%" or ddx like "403%" then 5 /* kidney failure */
			 when ddx like "I71%" or ddx like "441" then 6 /* Aortic aneurysm and dissection */
			 when ddx like "I50%" or ddx like "428" then 7 /*Heart failure*/

			 when ddx like "Q874%" or ddx like "7598%"/*Marfan syndrome*/
             or ddx like "Q796%" or ddx like "75683%" /*Ehlers-Danlos syndromes*/
             or ddx like "Q878W" /*Loeys-Dietz syndrome*/
             or ddx like "Q96%" or ddx like "7586%"  /*Turner's syndrome*/
             or ddx like "M31%" or ddx like "446%" or ddx like "446%"  /*Giant cell arteritis and Takayasu syndrome*/
             or ddx like "A51%" or ddx like "A52%" or ddx like "A53%" or ddx like "091%" or ddx like "092%" or ddx like "093%"
             or ddx like "094%" or ddx like "095%" or ddx like "096%" /*Syphilis*/ then 8 /*Exclusion for Aortic aneurysm*/

	         when ddx like "N11%" or ddx like "583W%" /*Nephritis*/ 
		     or ddx like "Q61%" or ddx like "7531%"/*cystic kidney disease*/
		     or ddx like "M30%" or ddx like "446%" /*Polyarteritis nodosa*/
		     or ddx like "M310%" /*Goodpasture's syndrome*/
             or ddx like "M311%"  /*Thrombotic microangiopathy*/ 
		     or ddx like "M313%"   /*Wegener's granulomatosis */
			 or ddx like "M316%" /*Microscopic polyangiitis*/
			 or ddx like "M32%" or ddx like "710%"  /*Lupus*/
			 or ddx like "N02B%" /*IgA nephropathy */ then 9 /*Exclusion for kidney failure*/

			 when ddx like "Q20%" or ddx like "Q21%" or ddx like "Q22%" or ddx like "Q23%" or ddx like "Q24%" or ddx like "Q25%" or ddx like "Q26%" or ddx like "Q27%"
			 or ddx like "Q28%" or ddx like "745%" or ddx like "746%" or ddx like "747%" /*Congenital heart malformations*/
			 or ddx like "140%" or ddx like "141%" or ddx like "422%" /*Miocarditis*/
			 or ddx like "I33%" or ddx like "I34%" or ddx like "I35%" or ddx like "I36%" or ddx like "I37%" or ddx like "I38%" or ddx like "I39%"
             or ddx like "421%" or ddx like "424%" /*Endocarditis & valve diseases*/
			 or ddx like "B20%" or ddx like "279%" /*HIV*/  then 10 /*Exclusion for heart failure*/

				  
       end;
quit;


proc sort data=death; by ID_mat D_diagnosis; run;

/*Death1 is a file that marks every dead woman in the cohort and attributes a death date for censoring.
  Dataset ready for the merge.*/
data death1;
   set death;
   by ID_mat;
   if first.ID_mat=1;
   drop B_date year D_diagnosis ddx;
run;
proc sort data=death1; by ID_mat; run;

/*After this, I create a dataset that has all the outcomes of interest and the 3 exclusion flag variables. 
  First, I remove all the deaths that are not autcomes */
data Death_cardio;
   set death;
   where D_diagnosis ne .;
   drop year b_date death;
run;
proc sort data=Death_cardio nodupkey; by ID_mat D_diagnosis; run;

proc transpose data=Death_cardio out=Deat_cardio2;
   var D_diagnosis;
   by ID_mat;
run;

/*Only conditions 1 to 7 are outcomes, 8 and 9 are just flag for ecluding patients*/
data Deat_cardio3;
   set Deat_cardio2;
   array Death[4] COL1-COL4;
   
     Coronary_death = "0";
     Hemorrhage_death = "0";
     Stroke_death="0";
     Diabetes_death = "0";
     Kidney_death = "0";
     Aortic_death = "0";
     HF_death="0";
     Aorta_Excl_Death = "0";
     Kidney_Excl_Death = "0";
     HF_Excl_Death="0";

   do i=1 to 4;
      if Death[i]=1 then Coronary_death="1";
      if Death[i]=2 then Hemorrhage_death="1";
      if Death[i]=3 then Stroke_death="1";
      if Death[i]=4 then Diabetes_death="1";
      if Death[i]=5 then Kidney_death="1";
      if Death[i]=6 then Aortic_death="1";
	  if Death[i]=7 then HF_death="1";
      if Death[i]=8 then Aorta_Excl_Death= "1";
      if Death[i]=9 then Kidney_Excl_Death="1";
	  if Death[i]=10 then HF_Excl_Death="1";
   end;

   if Coronary_death="1" or Hemorrhage_death="1" or Stroke_death="1" or Diabetes_death="1"
   or Kidney_death="1" or Aortic_death="1" or HF_death="1";

   drop _NAME_ COL1 COL2 COL3 COL4 i;
run;




/* M: NPR_DIA (cardiovascular diagnoses)*/

proc sql;
   create table Cardio as
   select a.id_mat, 
          a.b_date,
          a.grdbs,
          b.dx,
          . as Diagnosis length=3,
          b.dx_date as Cardio_dia_date,
          input(substr(a.B_date, 1, 4), best4.) as year
   from study_base as a
   inner join Repro2.Repro_npr_dia as b 
   on a.ID_mat = b.ID 
   where 
      (
          /* AMI  codes */
          b.dx like "I21%" or b.dx like "410%" or

          /* CIC (cerebrovascular ischemic conditions) and ICH */
          b.dx like "I60%" or b.dx like "I61%" or b.dx like "I62%" or b.dx like "I63%" or
          b.dx like "I65%" or b.dx like "I66%" or 
          b.dx like "430%" or b.dx like "431%" or b.dx like "432%" or b.dx like "433%" or
          b.dx like "434%" or b.dx like "435%" or

          /* Diabetes */
          b.dx like "E11%" or b.dx like "250%" or

          /* Kidney failure */
          b.dx like "N18%" or b.dx like "N19%" or b.dx like "I12%" or b.dx like "585%" or
          b.dx like "403%" or

          /* Aortic conditions */
          b.dx like "I71%" or b.dx like "441%" or

          /* Heart failure */
          b.dx like "I50%" or b.dx like "428%" or

          /* Marfan syndrome */
          b.dx like "Q874%" or b.dx like "759W%" or

          /* Ehlers-Danlos syndromes */
          b.dx like "Q796%" or b.dx like "756W%" or

          /* Loeys-Dietz syndrome */
          b.dx like "Q878W%" or

          /* Turner's syndrome */
          b.dx like "Q96%" or b.dx like "758G%" or

          /* Giant cell arteritis and Takayasu syndrome */
          b.dx like "M31%" or b.dx like "446%" or

          /* Syphilis */
          b.dx like "A51%" or b.dx like "A52%" or b.dx like "A53%" or
          b.dx like "091%" or b.dx like "092%" or b.dx like "093%" or
          b.dx like "094%" or b.dx like "095%" or b.dx like "096%" or
          (b.dx like "097%" and ICD = 8) or

          /* Nephritis */
          b.dx like "N11%" or b.dx like "583%" or

          /* Cystic kidney disease */
          b.dx like "Q61%" or b.dx like "753B%" or

          /* Polyarteritis nodosa and others */
          b.dx like "M30%" or

          /* Goodpasture's syndrome */
          b.dx like "M310%" or

          /* Thrombotic microangiopathy */
          b.dx like "M311%" or

          /* Wegener's granulomatosis */
          b.dx like "M313%" or

          /* Microscopic polyangiitis */
          b.dx like "M316%" or

          /* Lupus */
          b.dx like "M32%" or b.dx like "710%" or

          /* IgA nephropathy */
          b.dx like "N02B%" or

          /* Congenital heart malformations */
          b.dx like "Q20%" or b.dx like "Q21%" or b.dx like "Q22%" or
          b.dx like "Q23%" or b.dx like "Q24%" or b.dx like "Q25%" or
          b.dx like "Q26%" or b.dx like "Q27%" or b.dx like "Q28%" or
          b.dx like "745%" or b.dx like "746%" or b.dx like "747%" or

          /* Myocarditis */
          b.dx like "140%" or b.dx like "141%" or b.dx like "422%" or

          /* Endocarditis and valve diseases */
          b.dx like "I33%" or b.dx like "I34%" or b.dx like "I35%" or
          b.dx like "I36%" or b.dx like "I37%" or b.dx like "I38%" or
          b.dx like "I39%" or b.dx like "421%" or b.dx like "424%" or

          /* HIV */
          b.dx like "B20%" or b.dx like "279%"
      )
      and calculated year between 1992 and 2002
   order by ID_mat, b_date;
quit;




/* Here I classify the codes in the 7 diseases of interest*/
proc sql;
   update Cardio
       set Diagnosis=
       case when dx like "I21%" or dx like "410%" then 1
			when dx like "I60%" or dx like "I61%" or dx like "I62%" or dx like "430%" or dx like "431%" or dx like "432%" then 2
            when dx like "I63%" or dx like "I65%" or dx like "I66%" or dx like "433%" or dx like "434%" or dx like "435%" then 3
            when dx like "E11%" or dx like "250%" then 4 /* diabetes */
			when dx like "N18%" or dx like "N19%" or dx like "I12%" or dx like "585%" or dx like "403%" then 5 /* kidney failure */
			when dx like "I71%" or dx like "441" then 6 /* Aortic aneurysm and dissection */	
			when dx like "I50%" or dx like "428" then 7    /*Heart failure*/
       end;
quit;

