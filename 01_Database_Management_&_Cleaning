/*****************************       Database management and cleaning     ************************************/

/*key steps concerning the study population
	1. Select all births to nulliparous women
	2. Preparation to allow the extraction of relevant data (from MBR, NPR, migration, death etc.) 
	3  Data extraction from different registers
    4. Join together all the different datasets
    5. Compute the followup time
    6. Retrieve information on reused id
	7. Assign information from subsequent births 
	8. Select study population for time-dependent exposure (first births and for unexposed later exposed also that birth)
	9. Flag women that become exposed only in later births	(to allow their exclusion)
   10. Exclusions
   11. Variables formatting and dataset saving */


/* 1. Select all births to nulliparous women in the study period */

proc sql;
	create table study_base_all as
	select 		a.id_mat,
                a.malder as Age label="Age",
                a.MFODDATN label="mathernal birth", 
				a.AR,
				a.arbete as Job label="Job",
				a.paritet_f,
				a.b_date,
				a.grdbs, 
				a.Mfodland label="Maternal_Country",
				a.mlangd label="Maternal_height",
				a.mvikt label="Mother weight",
                a.mviktfv label="Weight_delivery",
				Rok1 label="smoke_during_pregn", 
				a.bordf2,

                /*Variables for infertility*/ 
                a.OFRIBARN label="Infertility time to pregnancy",
                a.OFRIABEF  label="Assisted reproduction", 
                a.OFRIIATG label="Infertility no intervention", 
                a.OFRIICSI  label="ICSI", 
                a.OFRIKIRU label="Infertility surgery", 
                a.OFRISTIM label="Infertility Ovulation stimulation",

				/*Variables for maternal diseases*/
				a.ASTMA,
				a.DIABETES,
				a.HYPERTON label="Hypertension",
				a.NJURSJUK label="Chronic kidney disease",
				a.SLE label="Lupus",
				a.ULCOLIT label="Inflamatory bowel disease",
				a.EPILEPSI label="Epilepsy"

    from		repro.repro_mbr_base as a
	where		a.ID_mat in	
	(select 	b.ID_mat from repro.repro_mbr_base as b where paritet_f = 1 AND
				ar GE 1992 AND ar LE 2002 AND (tid7dod NE '1' OR tiddodf NE '1' OR tidlevf EQ '' OR tsectio NE '1' ))
	order by	id_mat, paritet_f, b_date;
quit; 


/* 2. Preparation to allow the extraction of relevant data. Here I remove all the deliveries with same parity */
data study_base;
   set study_base_all;
   by id_mat paritet_f b_date;
   length c_date 4.;
   year=input(substr(b_date,1,4),4.);
   month=input(substr(b_date,6,2),2.);
   day=input(substr(b_date,9,2),2.);
   Birth_date=mdy(month,day, year);
   

   if first.paritet_f;
   if grdbs NE . 	then c_date = Birth_date - grdbs;
				else c_date = Birth_date - 280;
   if year le 2002 and year ge 1992;
   

   format c_date Birth_date yymmdd10.;
   drop day month year;
run;

proc sort data = study_base; by id_mat b_date; run;




/* 3. Data extraction from different registers */

/* A: MBR_IVF */
/*Extraction of women that accessed IVF */

proc sql;
create table 	study_ivf as
	select		a.id_mat, 
				a.b_date,
				 input(substr(a.b_date,1,4),4.) as Year,
		(case	when b.metod in ('', '00','01','02','06','11','13','15')	then 1
																			else 2 end)	as art_clinic	length 3 label 'ART (clinic): (1) IVF (2) ICSI' 
	from		study_base as a
	inner join	repro.repro_mbr_ivf as b
	on			a.ID_mat = b.ID_mat AND 
				a.b_date = b.b_date
				where calculated year le 2002 and calculated year ge 1992
	order by 	ID_mat, b_date;
quit;
proc sort data = study_ivf nodupkey; by id_mat b_date; run; 


/*Infertility from NPR*/
/* B: NPR_DIA (infertility): people with a diagnosis of infertility*/

proc sql;
   create table study_dia as
        select a.id_mat, 
			   a.b_date,
			   input(substr(a.b_date,1,4),4.) as Year_birth,
			(case when b.dx in ("628", "N97", "Z350", "V23A") and b.icd ne 8 then 1 end) as Infertility_dia,
			(case when b.dx in ("628", "N97", "Z350", "V23A") and b.icd ne 8 then dx end) as Infertility_code,
			(case when b.dx in ("628", "N97", "Z350", "V23A") and b.icd ne 8 then DX_date end) as Infertility_date
		from study_base as a
	    inner join repro.Repro_npr_dia as b
		on	a.ID_mat = b.ID
		where calculated Infertility_dia eq 1 and calculated Infertility_date < a.b_date and
		      calculated Year_birth ge 1992 and calculated Year_birth le 2002
	    order by 	ID_mat, b_date, calculated Infertility_date;
quit;


proc sort data=study_dia nodupkey dupout=Dup_Study_dia; by ID_mat B_date; run;


data study_dia1;
   set study_dia;
   by ID_mat b_date Infertility_date;

   if first.ID_mat=1 then count_infertility=1;

   if last.b_date=1;
run;
proc sort data=study_dia1; by ID_mat b_date Infertility_date descending count_infertility; run;

data study_dia_final;
   set study_dia1;
   by ID_mat b_date Infertility_date descending count_infertility;
   if first.ID_mat=1;
   drop Year_birth infertility_code;
run;



/* C: NPR_OP (Procedures from NPR)*/
proc sql;
   create table npr_procedures as
        select a.id_mat, 
			   a.b_date,
			   
               input(substr(a.b_date,1,4),4.) as Year,
			   input(substr(a.b_date,6,2),2.) as Month,
               input(substr(a.b_date,9,2),2.) as day,
			   mdy( calculated month, calculated day, calculated year) as Birth_date format ddmmyy10.,

			   input(substr(b.Pro_date,1,4),4.) as Year_P,
			   input(substr(b.Pro_date,6,2),2.) as Month_P,
               input(substr(b.Pro_date,9,2),2.) as day_P,
			   mdy( calculated Month_P, calculated day_P, calculated Year_P) as Procedure_date format ddmmyy10.,
			(case when b.pro in ("LCA30", "DL002", "DL003", "DL001", "DL007") then b.pro end) as Procedure_code,
			(case when b.pro in ("LCA30", "DL002", "DL003") then 1 end) as ART_pro,
			(case when b.pro in ("DL001", "DL007") then 1 end) as ICSI_pro,
			(case when b.pro in ("DL001", "DL007") then calculated Procedure_date end) as ICSI_pro_date
		from study_base as a
	    inner join repro.Repro_npr_op as b
		on	a.ID_mat = b.ID
		where calculated Year ge 1992 and calculated Year le 2002 and calculated Procedure_code ne " " and calculated Year_P le 2002 
              and calculated Procedure_date le calculated Birth_date
	    order by 	ID_mat, b_date, calculated Procedure_date;
quit;

/* Dataset ready for merging*/
data npr_procedures_final;
   set npr_procedures;
   by ID_mat b_date Procedure_date;
   if last.ID_mat=1;
   drop Year month day Year_P Month_P Day_P ICSI_pro ICSI_pro_date Procedure_code Birth_date Procedure_date;
run;



/* D: Diagnoses of ART from NPR */
proc sql;
   create table NPR_art_dia as
        select a.id_mat, 
			   a.b_date,

			   input(substr(a.b_date,1,4),4.) as Year,
			   input(substr(a.b_date,6,2),2.) as Month,
               input(substr(a.b_date,9,2),2.) as day,
			   mdy( calculated month, calculated day, calculated year) as Birth_date format ddmmyy10.,

			   input(substr(b.DX_date,1,4),4.) as Year_P,
			   input(substr(b.DX_date,6,2),2.) as Month_P,
               input(substr(b.DX_date,9,2),2.) as day_P,
			   mdy( calculated Month_P, calculated day_P, calculated Year_P) as ART_date format ddmmyy10.,
			   (case when b.dx like "Z312%" then b.dx end) as ART_code,
			   (case when b.dx like "Z312%" then 1 end) as Art_dia
		from study_base as a
	    inner join repro.Repro_npr_dia as b
		on	a.ID_mat = b.ID
		where calculated Art_dia=1 and calculated Year le 2002 and calculated Year_P le 2002 and calculated ART_date le calculated Birth_date
		order by 	ID_mat, b_date, calculated ART_date ;
quit;

data NPR_art_dia; /*Dataset ready for merging*/
   set NPR_art_dia;
    by ID_mat b_date ART_date;
    if first.ID_mat=1;
   drop year month day year_P month_P day_P ART_code Birth_date ART_date;
run;





/* E: Diagnosis of ICSI from NPR */
proc sql;
   create table NPR_ICSI_dia as
        select a.id_mat, 
			   a.b_date,

			   input(substr(a.b_date,1,4),4.) as Year,
			   input(substr(a.b_date,6,2),2.) as Month,
               input(substr(a.b_date,9,2),2.) as day,
			   mdy( calculated month, calculated day, calculated year) as Birth_date format ddmmyy10.,

			   input(substr(b.DX_date,1,4),4.) as Year_P,
			   input(substr(b.DX_date,6,2),2.) as Month_P,
               input(substr(b.DX_date,9,2),2.) as day_P,
			   mdy( calculated Month_P, calculated day_P, calculated Year_P) as ICSI_date format ddmmyy10.,
			   (case when b.dx="Z312B" then 1 end) as ICSI_dia,
			   (case when b.dx="Z312B" then b.dx end) as ICSI_code
		from study_base as a
	    inner join repro.Repro_npr_dia as b
		on	a.ID_mat = b.ID
		where calculated ICSI_dia=1 and calculated Year le 2002 and calculated Year_P le 2002 and calculated ICSI_date le calculated Birth_date
		order by 	ID_mat, b_date, calculated ICSI_date ;
quit;

data NPR_ICSI_dia; /*Dataset ready for merging*/
   set NPR_ICSI_dia;
    by ID_mat b_date ICSI_date;
    if last.B_date=1;
   drop year month day year_P month_P day_P ICSI_code Birth_date ICSI_date;
run;




