proc sql;
   create table Cardio4 as
   select a.*, b.Aorta_Dia_Exc, b.Kidney_Dia_Exc, b.HF_Dia_Exc
   from Cardio3 as a left join Cardio_exclusions2 as b
   on a.ID_mat=b.ID_mat;
