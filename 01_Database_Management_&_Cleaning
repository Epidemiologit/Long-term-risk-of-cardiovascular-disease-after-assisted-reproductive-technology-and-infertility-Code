proc sort data= Cardio out= Cardio_exclusions; by ID_mat descending dx; run;

/* First, I created 3 exclusion variable that remain on accross the different observation on each subject*/
data Cardio_exclusions1;
set Cardio_exclusions;
by ID_mat;

if first.ID_mat then Aorta_Dia_Exc = 0; 
if first.ID_mat then Kidney_Dia_Exc = 0; 
if first.ID_mat then HF_Dia_Exc = 0; 


if prxmatch("/Q874|759W|Q796|756W|Q878W|Q96|758G|M31|446|A51|A52|A53|091|092|093|094|095|096|097/", dx) then Aorta_Dia_Exc+1;
if prxmatch("/N11|583W|Q6|753B|M30|M310|446|M311|M313|M316|M32|710|N02B/", dx) then Kidney_Dia_Exc+1;
if prxmatch("/Q20|Q21|Q22|Q23|Q24|Q25|Q26|Q27|Q28|745|746|747|140|141|142|I33|I34|I35|I36|I37|I38|I39|421|424|B20|279/", dx) then HF_Dia_Exc+1;


if Aorta_Dia_Exc ne . and Aorta_Dia_Exc > 0 then Aorta_Dia_Exc = 1;
if Kidney_Dia_Exc ne . and Kidney_Dia_Exc> 0 then Kidney_Dia_Exc = 1;
if HF_Dia_Exc ne . and HF_Dia_Exc> 0 then HF_Dia_Exc = 1;
